{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@kerno/brand": ["packages/brand/src/index.ts"],
      "@kerno/contracts": ["packages/contracts/src/index.ts"],
      "@kerno/core": ["packages/core/src/index.ts"],
      "@kerno/indexer": ["packages/indexer/src/index.ts"],
      "@kerno/storage": ["packages/storage/src/index.ts"],
      "@kerno/daemon": ["packages/daemon/src/index.ts"],
      "@kerno/orchestrator": ["packages/orchestrator/src/index.ts"]
    }
  }
}
