{
  "name": "kerno",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22.13 <25"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "format:check": "tsx scripts/check-format.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:security": "vitest run tests/security",
    "test:cli": "vitest run tests/integration/cli.test.ts",
    "test:e2e": "npm run demo:record && npm run build --workspace @kerno/dashboard && playwright test",
    "test:app-server:live": "tsx scripts/app-server-live-smoke.ts",
    "judge": "tsx scripts/judge-demo.ts",
    "judge:live": "tsx scripts/judge-demo.ts --live",
    "demo:record": "tsx scripts/record-demo.ts",
    "demo:screenshot": "tsx scripts/capture-dashboard.ts",
    "benchmark:live": "tsx scripts/run-live-benchmark.ts",
    "package:plugin": "tsx scripts/package-plugin.ts",
    "plugin:smoke": "tsx scripts/plugin-smoke.ts",
    "setup:judge": "tsx scripts/setup-judge.ts",
    "clean-room": "tsx scripts/clean-room-check.ts"
  },
  "dependencies": {
    "@lezer/python": "^1.1.18",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "better-sqlite3": "^11.10.0",
    "ignore": "^7.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.8",
    "eslint": "^9.31.0",
    "globals": "^17.7.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  }
}
